<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_direct_print_agent_list" model="ir.ui.view">
        <field name="name">direct.print.agent.list</field>
        <field name="model">direct.print.agent</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="ip_address"/>
                <field name="port"/>
                <field name="active"/>
                <button name="test_connection" string="Test Connection" type="object" icon="fa-rss"/>
            </list>
        </field>
    </record>

    <record id="view_direct_print_agent_form" model="ir.ui.view">
        <field name="name">direct.print.agent.form</field>
        <field name="model">direct.print.agent</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="ip_address"/>
                            <field name="port"/>
                        </group>
                    </group>
                    <footer>
                        <button name="test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_direct_print_agent" model="ir.actions.act_window">
        <field name="name">Print Agents</field>
        <field name="res_model">direct.print.agent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
