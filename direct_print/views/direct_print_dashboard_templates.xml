<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="direct_print_dashboard">
        <div class="o_dashboards">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-12 mt-4">
                        <h1>Direct Print Dashboard</h1>
                        <p class="text-muted">Manage and monitor your local print agents from here.</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="card bg-primary text-white mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Total Agents</h5>
                                <p class="card-text h2">
                                    <t t-esc="len(env['direct.print.agent'].search([]))"/>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-white mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Active Agents</h5>
                                <p class="card-text h2">
                                    <t t-esc="len(env['direct.print.agent'].search([('active', '=', True)]))"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
