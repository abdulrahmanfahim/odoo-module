<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="direct_print.direct_print_dashboard">
        <div class="o_dashboards">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-12 mt-4">
                        <h1>Direct Print Dashboard</h1>
                        <p class="text-muted">Manage and monitor your local print agents from here.</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="card bg-primary text-white mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Total Agents</h5>
                                <p class="card-text h2">
                                    <!-- We will refine this later with JS data -->
                                    <t t-esc="props.totalAgents || 0"/>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-white mb-4">
                            <div class="card-body">
                                <h5 class="card-title">Active Agents</h5>
                                <p class="card-text h2">
                                    <t t-esc="props.activeAgents || 0"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
